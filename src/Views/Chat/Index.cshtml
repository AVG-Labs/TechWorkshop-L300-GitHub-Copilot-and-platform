@model ZavaStorefront.Models.ChatViewModel

@{
    ViewData["Title"] = "AI Chat";
}

<h2><i class="bi bi-chat-dots"></i> AI Chat</h2>
<p class="text-muted">Ask a question and the response will appear below.</p>

<div class="row">
    <div class="col-lg-8">

        <div class="mb-3">
            <label for="history" class="form-label fw-semibold">Conversation</label>
            <textarea id="history" class="form-control font-monospace" rows="14" readonly>@Model.History</textarea>
        </div>

        <form method="post">
            <input type="hidden" name="History" value="@Model.History" />
            <div class="input-group">
                <input type="text"
                       name="UserMessage"
                       id="UserMessage"
                       class="form-control"
                       placeholder="Type your message..."
                       value="@Model.UserMessage"
                       autofocus />
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-send"></i> Send
                </button>
            </div>
        </form>

    </div>
</div>

@section Scripts {
    <script>
        // Scroll the history textarea to the bottom after each response
        var ta = document.getElementById('history');
        ta.scrollTop = ta.scrollHeight;
    </script>
}
